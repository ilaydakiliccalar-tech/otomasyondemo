<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sanat Merkezi"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#6366F1"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Randevu Takip Sistemi"
        android:textSize="16sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="48dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gelecek Dersiniz"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yağlı Boya Atölyesi - Bugün 14:00"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnRandevuAl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="YENİ RANDEVU AL"
        android:backgroundTint="#6366F1"
        android:textColor="#FFFFFF"
        android:layout_marginTop="24dp"/>

</LinearLayout>
